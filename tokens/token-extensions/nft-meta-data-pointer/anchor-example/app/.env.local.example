# Copy this file to `.env.local` and fill in your own values.
# `.env.local` is gitignored by Next.js and must never be committed.

# RPC endpoint for the Solana connection.
# Defaults to https://rpc.magicblock.app/devnet when unset.
NEXT_PUBLIC_RPC=

# WebSocket RPC endpoint for the Solana connection.
# Defaults to wss://rpc.magicblock.app/devnet when unset.
NEXT_PUBLIC_WSS_RPC=

# RPC endpoint that supports the Metaplex DAS read API. Required for the
# read API features in this example. The public Solana RPC works for light
# use; for anything heavier, use a commercial provider like Quicknode
# (https://www.quicknode.com/chains/solana).
NEXT_PUBLIC_METAPLEX_READAPI_RPC=
